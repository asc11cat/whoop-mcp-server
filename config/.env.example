# OAuth app credentials from https://developer.whoop.com/
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret

# Redirect URI — must match what you registered in the Whoop dev dashboard.
# Default is a localhost loopback used by the one-time auth flow.
WHOOP_REDIRECT_URI=http://localhost:8765/callback

# Where the refresh-token bundle lives. Override when running in the
# container; the default below is for local dev.
# WHOOP_TOKEN_PATH=/app/config/token.json
